        -:   45:    bool unique[32];  //判断每个属性是否unique，是为true
        -:   46:    short primary_key;  //判断是否存在主键,-1为不存在，其他则为主键的所在位置
        -:   47:    bool has_index[32]; //判断是否存在索引
        -:   48:};
