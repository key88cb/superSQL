# ============================================================
# SuperSQL 环境变量配置
# 复制此文件为 .env 后直接使用，不要提交真实密钥到版本库
# ============================================================

# ---------- ZooKeeper ----------
ZK_TICK_TIME=2000
ZK_INIT_LIMIT=10
ZK_SYNC_LIMIT=5
ZK_MAX_CLIENT_CNXNS=60
ZK_AUTOPURGE_PURGE_INTERVAL=1

# ---------- Master ----------
MASTER_ZK_CONNECT=zk1:2181,zk2:2181,zk3:2181
MASTER_ELECTION_PATH=/masters
MASTER_META_PATH=/meta/tables
MASTER_ASSIGNMENT_PATH=/assignments
MASTER_HEARTBEAT_INTERVAL_MS=5000
MASTER_HEARTBEAT_TIMEOUT_MS=15000
MASTER_REBALANCE_INTERVAL_MS=30000
# 动态均衡触发阈值（某 RS 表数 / 平均表数）
MASTER_REBALANCE_RATIO=1.5

# ---------- RegionServer ----------
RS_ZK_CONNECT=zk1:2181,zk2:2181,zk3:2181
RS_THRIFT_PORT=9090
RS_HEARTBEAT_INTERVAL_MS=10000
RS_WAL_DIR=/data/wal
RS_DATA_DIR=/data/db
# miniSQL 可执行文件路径（容器内）
MINISQL_BIN=/opt/minisql/main
# 副本同步超时（毫秒）
RS_REPLICA_SYNC_TIMEOUT_MS=3000

# ---------- Client ----------
CLIENT_ZK_CONNECT=zk1:2181,zk2:2181,zk3:2181
CLIENT_CACHE_TTL_MS=30000
CLIENT_MASTER_RPC_TIMEOUT_MS=5000
CLIENT_RS_RPC_TIMEOUT_MS=10000

# ---------- Java 公共 ----------
JAVA_OPTS=-Xms256m -Xmx512m
LOG_LEVEL=INFO
